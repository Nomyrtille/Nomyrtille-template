# ========================
# App
# ========================
APP_NAME=mon-app
APP_ENV=production        # production | staging | development
APP_PORT=3000
APP_URL=https://mon-app.nomyrtille.com

# ========================
# Base de données
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mon_app
DB_USER=postgres
DB_PASSWORD=

# ========================
# Redis (cache / sessions)
# ========================
REDIS_URL=redis://localhost:6379

# ========================
# Auth / JWT
# ========================
JWT_SECRET=
SESSION_SECRET=

# ========================
# Emails
# ========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@nomyrtille.com

# ========================
# Storage S3-compatible
# ========================
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-1

# ========================
# Monitoring
# ========================
SENTRY_DSN=
